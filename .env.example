# Anthropic — required for chat + content generation
ANTHROPIC_API_KEY=

# Supabase — required for persistence (sites, visitors, preferences, chat_turns)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional — Unsplash for video thumbnail seeds
UNSPLASH_ACCESS_KEY=

# Adapter selector: 'mock' (v0) or 'youtube' (v0.5 — Electron sidecar)
FEED_ADAPTER=mock

# Dev-only flags
NEXT_PUBLIC_DEVTOOLS_ENABLED=true
