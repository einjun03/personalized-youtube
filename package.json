{
  "name": "showcase",
  "private": true,
  "version": "0.0.1",
  "description": "Personalizable YouTube clone — chat-driven personalization showcase",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:visual": "turbo run test:visual",
    "migrate": "node --env-file=.env --import tsx scripts/migrate.ts",
    "seed": "node --env-file=.env --import tsx scripts/seed.ts",
    "patch-config": "node --env-file=.env --import tsx scripts/patch-base-config.ts",
    "clean-thumbs": "node --env-file=.env --import tsx scripts/clean-thumbs.ts",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@supabase/supabase-js": "^2.45.0",
    "@showcase/shared": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "@types/node": "^20.14.0"
  }
}
